---
import '../../styles/global.css';
import TopBar from '../../components/TopBar.astro';

type Entry = {
	slug: string | null;
	title: string;
	blurb: string;
	status: 'live' | 'coming-soon';
};

const entries: Entry[] = [
	{
		slug: 'system-overview',
		title: 'System overview',
		blurb: 'Top-level concerns above extract and deliver.',
		status: 'live',
	},
	{
		slug: 'extract-architecture',
		title: 'Extract',
		blurb: 'Messy prototype → trustworthy artifacts + build.',
		status: 'live',
	},
	{
		slug: 'deliver-architecture',
		title: 'Deliver',
		blurb: 'Known issue → validated change through draft PR.',
		status: 'live',
	},
	{
		slug: null,
		title: 'discover',
		blurb: 'Messy signals → trustworthy intent.',
		status: 'coming-soon',
	},
	{
		slug: null,
		title: 'validate',
		blurb: 'Shipped change → outcome truth.',
		status: 'coming-soon',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>Architecture — autoship</title>
		<meta
			name="description"
			content="Canonical architecture docs for each autoship module."
		/>
	</head>
	<body class="bg-[color:var(--color-lf-bg)] text-[color:var(--color-lf-text-2)] font-sans">
		<TopBar />

		<main class="max-w-2xl mx-auto px-6 py-16">
			<h1 class="text-2xl font-medium tracking-tight text-[color:var(--color-lf-text)] mb-10">
				Architecture
			</h1>

			<ul class="divide-y divide-[color:var(--color-lf-border)]">
				{entries.map((entry) => {
					const isLive = entry.status === 'live' && entry.slug;
					const Wrapper = isLive ? 'a' : 'div';
					const wrapperProps = isLive
						? {
								href: `/architecture/${entry.slug}/`,
								class: 'group block py-4 transition-colors',
							}
						: {
								class: 'block py-4 opacity-55',
							};
					return (
						<li>
							<Wrapper {...wrapperProps}>
								<div class="flex items-baseline gap-2">
									<span
										class:list={[
											'text-base font-medium text-[color:var(--color-lf-text)]',
											isLive &&
												'group-hover:text-[color:var(--color-lf-accent-strong)] transition-colors',
										]}
									>
										{entry.title}
									</span>
									{!isLive && (
										<span class="text-[10.5px] uppercase tracking-[0.12em] text-[color:var(--color-lf-text-3)]">
											coming soon
										</span>
									)}
								</div>
								<p class="mt-1 text-sm text-[color:var(--color-lf-text-3)] leading-[1.5]">
									{entry.blurb}
								</p>
							</Wrapper>
						</li>
					);
				})}
			</ul>
		</main>
	</body>
</html>
