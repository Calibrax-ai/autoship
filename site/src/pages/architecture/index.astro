---
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import TopBar from '../../components/TopBar.astro';

const pieces = await getCollection('architecture');
// Desired order: system overview, extract, deliver
const order = [
	'system-overview',
	'extract-architecture',
	'deliver-architecture',
];
pieces.sort((a, b) => {
	const ai = order.indexOf(a.id.replace(/\.md$/, ''));
	const bi = order.indexOf(b.id.replace(/\.md$/, ''));
	return (ai < 0 ? 99 : ai) - (bi < 0 ? 99 : bi);
});
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>Architecture — autoship</title>
		<meta
			name="description"
			content="System overview, extract, and deliver: autoship's canonical architecture documents."
		/>
	</head>
	<body class="bg-[color:var(--color-lf-bg)] text-[color:var(--color-lf-text-2)] font-sans">
		<TopBar />

		<main class="max-w-3xl mx-auto px-6 py-20">
			<header class="mb-16">
				<p class="text-xs uppercase tracking-[0.15em] text-[color:var(--color-lf-text-3)] mb-4">
					Architecture
				</p>
				<h1 class="text-5xl md:text-6xl font-medium tracking-[-0.02em] leading-[1.05] text-[color:var(--color-lf-text)]">
					How autoship is built.
				</h1>
				<p class="mt-6 text-xl leading-[1.4] tracking-[-0.005em] text-[color:var(--color-lf-text-2)] max-w-[36rem]">
					Canonical architecture docs for each module, and the top-level concern map that sits above them.
				</p>
			</header>

			<ul class="flex flex-col divide-y divide-[color:var(--color-lf-border)]">
				{pieces.map((entry) => (
					<li class="py-8">
						<a
							href={`/architecture/${entry.id.replace(/\.md$/, '')}/`}
							class="group block"
						>
							<div class="flex items-center gap-3 text-xs uppercase tracking-[0.15em] text-[color:var(--color-lf-text-3)] mb-3">
								<span>{entry.data.eyebrow}</span>
							</div>
							<h2 class="text-2xl md:text-3xl font-medium tracking-[-0.015em] leading-[1.15] text-[color:var(--color-lf-text)] group-hover:text-[color:var(--color-lf-accent-strong)] transition-colors">
								{entry.data.title}
							</h2>
							{entry.data.description && (
								<p class="mt-3 text-lg leading-[1.5] text-[color:var(--color-lf-text-2)] max-w-[34rem]">
									{entry.data.description}
								</p>
							)}
						</a>
					</li>
				))}
			</ul>
		</main>

		<footer class="max-w-3xl mx-auto px-6 py-16 text-sm text-[color:var(--color-lf-text-3)] border-t border-[color:var(--color-lf-border)]">
			<p>
				More: <a class="underline underline-offset-2" href="/ideas/">Ideas</a>
				·
				<a class="underline underline-offset-2" href="/">Docs</a>
			</p>
		</footer>
	</body>
</html>
