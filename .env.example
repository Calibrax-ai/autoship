PORT=8787

# Trigger.dev runtime auth for the local receiver (tsx src/server.ts). Use a
# tr_dev_* key so local runs queue to the dev env. The project ref is
# hardcoded in trigger.config.ts and not needed here.
TRIGGER_SECRET_KEY=tr_dev_set_me

# Claude Code subprocess auth. Required in Trigger.dev deploys; optional
# locally on macOS where the Keychain ("Claude Code-credentials") satisfies
# the CLI on its own. Generate with `claude setup-token` — produces a
# long-lived OAuth token (sk-ant-oat01-...) tied to your Pro/Max subscription.
#
# The Trigger.dev task stages this into $HOME/.claude/.credentials.json at
# run start (see stageClaudeCredentials in src/trigger/autoship-run.ts).
# Filesystem auth bypasses claude-code@2.1.x's env scrubbing, which strips
# auth vars from Bash-spawned worker subprocesses (controller -> worker hop).
# CLAUDE_CODE_OAUTH_TOKEN=

# Linear webhook verification. Linear sends the raw-body HMAC in `Linear-Signature`.
LINEAR_WEBHOOK_SECRET=set_me

# Optional. If set, the webhook bridge can acknowledge agent sessions.
LINEAR_API_KEY=lin_api_set_me

# Per-project repo + Linear project mapping lives in src/projects.config.ts.
# Add a project: append an entry there and redeploy.

AUTOSHIP_LINEAR_AUTO_STATE="Run Agent"
# Moving a parent issue here creates child issues from the approved breakdown.
AUTOSHIP_LINEAR_BREAKDOWN_APPROVED_STATE="Breakdown Approved"
# Optional supervised-mode compatibility only. Disabled by default.
# AUTOSHIP_LINEAR_BUILD_STATE="Spec Ready"

# Optional escape hatches. Normally the runner resolves these from the names above using LINEAR_API_KEY.
# AUTOSHIP_LINEAR_AUTO_STATE_ID=
# AUTOSHIP_LINEAR_BREAKDOWN_APPROVED_STATE_ID=
# AUTOSHIP_LINEAR_BUILD_STATE_ID=

# Runner execution.
AUTOSHIP_REPOS_ROOT=./runs/repos
AUTOSHIP_PACKAGE=@cs-calibrax/autoship@latest
AUTOSHIP_CLAUDE_OUTPUT_FORMAT=stream-json
AUTOSHIP_CLAUDE_VERBOSE=true
AUTOSHIP_LINEAR_MCP_ENABLED=true
AUTOSHIP_POST_TO_LINEAR=true

# Cross-turn session continuity (0.2.0+).
# How long the runner parks at wait.forToken before timing out and posting Needs Attention.
AUTOSHIP_WAITPOINT_TIMEOUT_DAYS=2

# Optional Supabase Storage (S3-compatible) for mirroring claude session JSONL
# transcripts across container teardowns. If unset, --resume only works while
# the original container is still warm; long parks degrade to graceful cold-start.
# AUTOSHIP_SESSION_STORE_BUCKET=autoship-claude-sessions
# AUTOSHIP_SESSION_STORE_PREFIX=claude-sessions/
# AUTOSHIP_SESSION_STORE_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
# AUTOSHIP_SESSION_STORE_REGION=us-east-1
# AUTOSHIP_SESSION_STORE_ACCESS_KEY_ID=
# AUTOSHIP_SESSION_STORE_SECRET_ACCESS_KEY=
